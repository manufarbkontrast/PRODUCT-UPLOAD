# ============================================================
# SPZ Product Upload ("erfassung") — Hetzner/Docker Konfiguration
# Kopiere diese Datei nach .env (lokal) bzw. deploy/.env (Server) und
# fülle die Werte aus. NIEMALS echte Secrets in dieses Beispiel eintragen.
# ============================================================

# --- App Basics -----------------------------------------------
# Volle URL, unter der die App öffentlich erreichbar ist — MUSS den
# Base-Path enthalten (siehe unten), sonst zeigen serverseitig gebaute
# absolute Links (z.B. Retry-Webhooks, OAuth-Redirects) ins Leere.
NEXT_PUBLIC_SITE_URL=https://167.233.218.238/erfassung
AUTH_DISABLED=false
# Aktiviert next.config.ts -> output: "standalone" für den Docker-Build.
# Lokal (npm run dev / npm test) NICHT setzen, sonst kein Standalone-Build.
DOCKER_BUILD=1

# --- Base-Path (Pflicht) ---------------------------------------
# Diese App läuft auf dem gemeinsamen Hetzner-Host (167.233.218.238) NEBEN
# "brain-cockpit" (auf "/") unter dem Pfad "/erfassung" — dadurch teilen
# sich beide Apps dasselbe Supabase-Auth-Cookie (Single-Sign-On).
# next.config.ts liest diesen Wert als einzige Quelle für basePath,
# assetPrefix UND die client-sichtbare Variable (siehe lib/base-path.ts).
# Fällt next.config.ts auf "/erfassung" zurück, falls hier leer.
NEXT_PUBLIC_BASE_PATH=/erfassung

# --- Supabase (Pflicht) -----------------------------------------
# Gemeinsames "mycrafton"-Projekt (shared DB mit Brain Cockpit).
# profiles / jtl_articles / jtl_stock_locations werden vom Cockpit
# synced; products / product_images / Storage-Buckets gehoeren
# diesem Tool (siehe supabase/migrations/20260715_*.sql).
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Gemini (Pflicht — Bildverarbeitung) -------------------------
# API-Key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Admin / App-Login (Pflicht) ---------------------------------
ADMIN_TOKEN=
APP_USERNAME=
APP_PIN=

# ============================================================
# --- Google Drive / Sheets — OPTIONAL ------------------------
# Die App funktioniert beim ERSTEN Deploy vollständig OHNE diese Werte:
# Fotos bleiben dann einfach in Supabase Storage, der Drive-Upload-Schritt
# wird sauber übersprungen (Produkt-Status wird normal 'uploaded', NICHT
# 'drive_error') — siehe lib/google/auth.ts: isDriveConfigured().
# Erst wenn GOOGLE_CLIENT_ID+SECRET (OAuth2) ODER GOOGLE_SERVICE_ACCOUNT_JSON
# gesetzt sind, versucht die App den Drive-Upload.
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://167.233.218.238/erfassung/api/google/callback
# Base64-encoded JSON vom initialen OAuth-Flow (Alternative zu Client-ID/Secret
# allein — wird nach Autorisierung unter /api/google/auth angezeigt)
GOOGLE_OAUTH_TOKENS=
# Alternative zu OAuth2: Base64-encoded Service-Account-JSON
GOOGLE_SERVICE_ACCOUNT_JSON=

# Nur relevant, wenn Drive oben konfiguriert ist:
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=
REORDER_SHEETS_FOLDER_ID=

# --- JTL / Misc (optional) ---------------------------------------
# Kanonischer JTL-Pfad ist /api/jtl-lookup (mycrafton-Tabellen jtl_articles/
# jtl_stock_locations, kein Env noetig). JTL_STOCKS_FOLDER_ID/JTL_API_* sind
# nur noch Legacy-Fallbacks (Google-Drive-Cache via /api/jtl-warmup bzw.
# Live-API-Proxy) und optional.
JTL_STOCKS_FOLDER_ID=
JTL_API_URL=
JTL_API_KEY=

# --- n8n Webhook (optional) ---------------------------------------
# Nur nötig, wenn Bildverarbeitung über eine externe n8n-Instanz laufen
# soll statt direkt per Gemini (Standardpfad ohne diese Variable). n8n ist
# NICHT Teil von deploy/docker-compose.yml — falls genutzt, muss
# INTERNAL_APP_URL den Base-Path enthalten, damit n8n-Callbacks an
# /api/webhooks/n8n ankommen (z.B. https://167.233.218.238/erfassung).
N8N_WEBHOOK_URL=
INTERNAL_APP_URL=https://167.233.218.238/erfassung

# ============================================================
# Die folgenden Variablen (SITE_DOMAIN/ACME_EMAIL/N8N_DOMAIN/Postgres/
# pgAdmin/Mailpit) werden NUR vom lokalen Entwicklungs-Compose-Setup im
# Repo-Root (docker-compose.yml, Profile "dev"/"prod", NICHT Teil des
# /erfassung-Deploys unter deploy/) benötigt — siehe env.example dort.
# Für den Hetzner-Deploy unter deploy/ sind sie irrelevant.
# ============================================================
