# ============================================================
# SPZ Product Upload — Hetzner/Docker Konfiguration
# Kopiere diese Datei nach .env und fülle die Werte aus.
# ============================================================

# --- Caddy / Reverse-Proxy ----------------------------------
SITE_DOMAIN=spz.example.com
ACME_EMAIL=admin@example.com
# Optional: zweite Subdomain für n8n
N8N_DOMAIN=

# --- App Basics ---------------------------------------------
NEXT_PUBLIC_SITE_URL=https://spz.example.com
AUTH_DISABLED=false
DOCKER_BUILD=1

# --- Supabase -----------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Google OAuth (Drive + Sheets) --------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://spz.example.com/api/google/callback
# Base64-encoded JSON vom initial OAuth-Flow
GOOGLE_OAUTH_TOKENS=

# --- Google Drive / Sheets IDs ------------------------------
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=
REORDER_SHEETS_FOLDER_ID=

# --- JTL / Misc ---------------------------------------------
JTL_STOCKS_FOLDER_ID=
JTL_API_URL=
JTL_API_KEY=
GEMINI_API_KEY=

# --- Webhooks / n8n (optional) ------------------------------
N8N_WEBHOOK_URL=
INTERNAL_APP_URL=http://web:3000
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=
N8N_SMTP_HOST=
N8N_SMTP_PORT=
N8N_SMTP_SSL=
N8N_SMTP_USER=
N8N_SMTP_PASS=
N8N_SMTP_SENDER=
N8N_PROTOCOL=https
N8N_HOST=

# --- Postgres (nur wenn 'db'-Service genutzt wird) ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=app
DATABASE_URL=

# --- Admin / App Login --------------------------------------
ADMIN_TOKEN=
APP_USERNAME=
APP_PIN=

# --- pgAdmin (nur dev) --------------------------------------
PGADMIN_DEFAULT_EMAIL=
PGADMIN_DEFAULT_PASSWORD=
