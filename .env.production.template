# ============================================================
# SPZ Product Upload - Produktionskonfiguration
# Domain: produkt.crftn.de
# ============================================================

# Anwendung
NODE_ENV=production

# Compose-Profile: prod fuer Produktion
COMPOSE_PROFILES=prod

# ┌─────────────────────────────────────────────────────────┐
# │ DOMAIN & SSL                                            │
# └─────────────────────────────────────────────────────────┘
NEXT_PUBLIC_SITE_URL=https://produkt.crftn.de
INTERNAL_APP_URL=https://produkt.crftn.de
SITE_DOMAIN=produkt.crftn.de
ACME_EMAIL=HIER_EMAIL_EINTRAGEN
SESSION_SECRET=HIER_SESSION_SECRET_EINTRAGEN
# Optional: Subdomain fuer n8n (z.B. n8n.crftn.de)
N8N_DOMAIN=n8n.crftn.de

# ┌─────────────────────────────────────────────────────────┐
# │ SUPABASE                                                │
# └─────────────────────────────────────────────────────────┘
NEXT_PUBLIC_SUPABASE_URL=HIER_SUPABASE_URL_EINTRAGEN
NEXT_PUBLIC_SUPABASE_ANON_KEY=HIER_SUPABASE_ANON_KEY_EINTRAGEN
SUPABASE_SERVICE_ROLE_KEY=HIER_SUPABASE_SERVICE_ROLE_KEY_EINTRAGEN

# ┌─────────────────────────────────────────────────────────┐
# │ POSTGRES (lokale DB fuer n8n etc.)                      │
# └─────────────────────────────────────────────────────────┘
POSTGRES_USER=mw
POSTGRES_DB=spz-product-upload
POSTGRES_PASSWORD=HIER_POSTGRES_PASSWORT_EINTRAGEN

# ┌─────────────────────────────────────────────────────────┐
# │ AUTH (App-Login: Benutzername + 4-Ziffern PIN)          │
# └─────────────────────────────────────────────────────────┘
APP_USERNAME=mw
APP_PIN=HIER_PIN_EINTRAGEN
ADMIN_TOKEN=HIER_ADMIN_TOKEN_EINTRAGEN
AUTH_DISABLED=false

# ┌─────────────────────────────────────────────────────────┐
# │ GOOGLE OAuth2                                           │
# └─────────────────────────────────────────────────────────┘
GOOGLE_CLIENT_ID=HIER_GOOGLE_CLIENT_ID_EINTRAGEN
GOOGLE_CLIENT_SECRET=HIER_GOOGLE_CLIENT_SECRET_EINTRAGEN
GOOGLE_REDIRECT_URI=https://produkt.crftn.de/api/google/callback

# ┌─────────────────────────────────────────────────────────┐
# │ GOOGLE DRIVE / SHEETS                                   │
# └─────────────────────────────────────────────────────────┘
GOOGLE_DRIVE_FOLDER_ID=HIER_DRIVE_FOLDER_ID_EINTRAGEN
GOOGLE_SHEET_ID=HIER_SHEET_ID_EINTRAGEN
GOOGLE_SHEET_NAME=Tabellenblatt1
GOOGLE_OAUTH_TOKENS=HIER_BASE64_ENCODED_TOKENS_EINTRAGEN
GOOGLE_SERVICE_ACCOUNT_JSON=HIER_BASE64_ENCODED_SERVICE_ACCOUNT_EINTRAGEN

# ┌─────────────────────────────────────────────────────────┐
# │ JTL Bestandsdaten (Google Drive Ordner mit JSON-Dateien)│
# └─────────────────────────────────────────────────────────┘
JTL_STOCKS_FOLDER_ID=HIER_JTL_STOCKS_FOLDER_ID_EINTRAGEN

# ┌─────────────────────────────────────────────────────────┐
# │ GEMINI API (Bildbearbeitung via Gemini Flash)           │
# └─────────────────────────────────────────────────────────┘
GEMINI_API_KEY=HIER_GEMINI_API_KEY_EINTRAGEN

# ┌─────────────────────────────────────────────────────────┐
# │ SHOPIFY (optional)                                      │
# └─────────────────────────────────────────────────────────┘
SHOPIFY_STORE_DOMAIN=HIER_SHOPIFY_DOMAIN_EINTRAGEN
SHOPIFY_ACCESS_TOKEN=HIER_SHOPIFY_ACCESS_TOKEN_EINTRAGEN

# ┌─────────────────────────────────────────────────────────┐
# │ REMOVE.BG (optional)                                    │
# └─────────────────────────────────────────────────────────┘
REMOVEBG_API_KEY=

# ┌─────────────────────────────────────────────────────────┐
# │ n8n (optional, nur wenn n8n benoetigt wird)             │
# └─────────────────────────────────────────────────────────┘
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=HIER_N8N_PASSWORT_EINTRAGEN
N8N_EMAIL_MODE=smtp
N8N_SMTP_HOST=
N8N_SMTP_PORT=587
N8N_SMTP_SSL=true
N8N_SMTP_USER=
N8N_SMTP_PASS=
N8N_SMTP_SENDER=
N8N_PROTOCOL=https
N8N_HOST=
N8N_WEBHOOK_URL=
